{
	"name": "atmosx-nwws-parser",
	"version": "1.0.3180",
	"description": "NOAA Weather Wire Parser - Built for standalone and Project AtmosphericX Integration.",
	"main": "dist/cjs/index.cjs",
	"module": "dist/esm/index.mjs",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/AtmosphericX/atmosx-nwws-parser.git",
		"branch": "beta"
	},
	"scripts": {
		"start": "cd ./test && node ./index.js",
    	"build": "tsup && cd ./test && node ./index.js",
		"publish": "tsup && npm publish --access public",
		"publish-beta": "tsup && npm publish --tag beta --access public"
	},
	"keywords": [
		"NWWS",
		"NOAA Weather Wire Service",
		"TypeScript",
		"XMPP",
		"Parser",
		"JavaScript",
		"CommonJS",
		"ESM"
	],
	"author": "k3yomi, StarflightWx",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/AtmosphericX/atmosx-nwws-parser/issues"
	},
	"homepage": "https://github.com/AtmosphericX/atmosx-nwws-parser#readme",
	"dependencies": {
		"@xmpp/client": "0.14.0",
		"axios": "1.13.2",
		"better-sqlite3": "11.10.0",
		"croner": "10.0.1",
		"jszip": "3.10.1",
		"polygon-clipping": "0.15.7",
		"say": "0.16.0",
		"shapefile": "0.6.6",
		"typescript": "5.9.3",
